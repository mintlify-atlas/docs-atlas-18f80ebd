  "keyFeatures": [
    "Multiple extraction strategies (simple, parallel, sequential, auto-merge, double-pass)",
    "Token-aware chunking and batching",
    "Schema validation with Ajv and automatic retries",
    "Schema-aware merge and deduplication",
    "Support for multiple AI providers (OpenAI, Anthropic, Google, OpenRouter)",
    "Progress tracking and event hooks",
    "CLI tool for extraction and artifact verification",
    "TypeScript-first with full type inference"
  ],
  "publicApiSurface": [
    "extract({ artifacts, schema, strategy, events? })",
    "simple({ model })",
    "parallel({ model, mergeModel, chunkSize, concurrency })",
    "sequential({ model, chunkSize })",
    "parallelAutoMerge({ model, dedupeModel, chunkSize, concurrency })",
    "sequentialAutoMerge({ model, dedupeModel, chunkSize })",
    "doublePass({ model, mergeModel, chunkSize })",
    "doublePassAutoMerge({ model, dedupeModel, chunkSize })",
    "urlToArtifact(url, options?)",
    "fileToArtifact(buffer, options)",
    "registerArtifactInputParser(parser)",
    "validateSerializedArtifacts(data)",
    "parseSerializedArtifacts(data)",
    "hydrateSerializedArtifacts(data)",
    "parseInputToArtifacts(input)",
    "struktur extract-file --schema <path> --input <path> --model <provider/model> --strategy <name>",
    "struktur verify --input <path>",
    "struktur auth set --provider <name> --token <value>",
    "struktur models --provider <name>"
  ]
}
